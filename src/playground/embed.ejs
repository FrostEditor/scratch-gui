<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="google" value="notranslate">
    <title><%= htmlWebpackPlugin.options.title %></title>
    <link rel="icon" type="image/x-icon" href="<%= htmlWebpackPlugin.options.root %>favicon.ico">
    <style>
      .splash-screen {
        position: absolute;
        width: 100%;
        height: 100%;
        top: 0;
        left: 0;
        background-color: #FF9B33;
        color: white;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        font-family: "Helvetica Neue", Helvetica, Arial, sans-serif;
      }
      .splash-screen[hidden] {
        display: none;
      }
      /* Snowflake loading animation */
      .splash-spinner {
        font-size: 48px;
        line-height: 1;
      }
      .splash-spinner:after {
        content: "❄";
        display: block;
        color: white;
        animation: splash-snow 1.6s ease-in-out infinite alternate;
      }
      @keyframes splash-snow {
        0% { transform: translateY(20px) scale(0.7); opacity: 0; }
        60% { transform: translateY(0px) scale(1.0); opacity: 1; }
        100% { transform: translateY(-6px) scale(0.95); opacity: 0.6; }
      }
    </style>
  </head>
  <body>
    <noscript>
      <div class="splash-screen">
        <h1>This embed requires JavaScript</h1>
      </div>
    </noscript>

    <div class="splash-screen" hidden id="splash-need-js">
      <div class="splash-spinner"></div>
    </div>

    <script>
      (function() {
        'use strict';

        var splash = document.getElementById('splash-need-js');
        splash.hidden = false;

        window.SplashEnd = () => {
          splash.hidden = true;
        };
      }());
    </script>

    <div id="app"></div>
  </body>
</html>
